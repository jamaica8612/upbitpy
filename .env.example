# ---- Backend (FastAPI) — prefix USL_ ----------------------------------
# Candle/metadata storage root (default: ./data)
#USL_DATA_DIR=./data

# Upbit public API host (no API key needed; quotation endpoints only)
#USL_UPBIT_BASE_URL=https://api.upbit.com

# Backtest defaults (all user-overridable per request)
#USL_DEFAULT_FEE_RATE=0.0005
#USL_DEFAULT_SLIPPAGE_RATE=0.0005
#USL_DEFAULT_INITIAL_CAPITAL=10000000
#USL_DEFAULT_MIN_ORDER_KRW=5000

# Optimization guardrails
#USL_OPTIMIZATION_MAX_COMBINATIONS=500

# ---- Frontend (Next.js) ------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
